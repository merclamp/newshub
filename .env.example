# Скопируйте в .env и заполните под себя:  cp .env.example .env

# --- Telegram-бот дайджестов (опционально) ---
# Токен от @BotFather. Бот запускается профилем: docker compose --profile bot up -d
BOT_TOKEN=
# Как часто слать дайджест подписчикам (в часах)
DIGEST_INTERVAL_HOURS=6
# Максимум материалов от одного источника в дайджесте
DIGEST_MAX_PER_SOURCE=5

# --- Сборщик новостей ---
# Интервал опроса источников (в секундах)
FETCH_INTERVAL_SECONDS=300
# Сколько дней хранить материалы в Redis
ARTICLE_TTL_DAYS=7

# --- API ---
# Разрешённые CORS-источники через запятую (для продакшена укажите домен)
CORS_ORIGINS=*
