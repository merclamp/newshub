# Скопируйте в .env и заполните под себя:  cp .env.example .env

# --- Сборщик новостей ---
# Интервал опроса источников (в секундах)
FETCH_INTERVAL_SECONDS=3600
# Сколько дней хранить материалы в Redis
ARTICLE_TTL_DAYS=7

# --- API ---
# Разрешённые CORS-источники через запятую (для продакшена укажите домен)
CORS_ORIGINS=*
